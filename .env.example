# Feishu App credentials (required)
FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret
BOT_NAME=your_bot_name

# Kiro CLI path (optional, defaults to "kiro-cli")
# KIRO_CLI_PATH=/path/to/kiro-cli

# Working directory for session workspaces (optional)
# WORKING_DIR=/tmp/feishu-kirocli-bot-workspaces

# Idle timeout in seconds, 0 = never (optional, default 300)
# IDLE_TIMEOUT=300

# MCP servers config as JSON array (optional)
# MCP_SERVERS=[]

# Debug mode (optional)
# DEBUG=false
