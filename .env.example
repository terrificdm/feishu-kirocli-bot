# Feishu App credentials (required)
FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret
BOT_NAME=your_bot_name

# Kiro CLI path (optional, defaults to "kiro-cli")
# KIRO_CLI_PATH=/path/to/kiro-cli

# Workspace mode (optional, default "per_chat")
# - per_chat: Each chat gets its own subdirectory under WORKING_DIR
# - fixed: All chats share the same WORKING_DIR (for project-specific .kiro config)
# WORKSPACE_MODE=per_chat

# Working directory for session workspaces (optional)
# For per_chat mode: base directory, each chat gets a subdirectory
# For fixed mode: the exact directory to use (can contain .kiro/ config)
# WORKING_DIR=/tmp/feishu-kirocli-bot-workspaces

# Idle timeout in seconds, 0 = never (optional, default 300)
# IDLE_TIMEOUT=300
# AUTO_APPROVE=false                   # Auto-approve all Kiro permission requests (default: false)

# Log file path (optional, logs to stdout only if not set)
# LOG_FILE=/var/log/feishu-kirocli-bot.log

# Debug mode (optional)
# DEBUG=false
